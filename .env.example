# Copy this file to .env and update values before starting the app
# === SERVER CONFIGURATION ===
NODE_ENV=production
PORT=3000

# === BUSINESS CONFIGURATION ===
BUSINESS_NAME=Hoppokart
ADMIN_PASSWORD=your_secure_password_min_8_chars

# === SECURITY ===
JWT_SECRET=generate-a-random-long-string-here-at-least-32-characters

# === PAYMENT GATEWAY (RAZORPAY) ===
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# === EMAIL NOTIFICATIONS (GMAIL) ===
EMAIL_ENABLED=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password-16-digits

# === WHATSAPP INTEGRATION ===
WHATSAPP_ENABLED=false
WHATSAPP_NUMBER=919876543210
